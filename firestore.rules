rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get the current user's document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check if current user has a specific role
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    // Check if current user is admin
    function isAdmin() {
      return hasRole('admin');
    }
    
    // Check if current user is staff or admin
    function isStaffOrAdmin() {
      return hasRole('staff') || hasRole('admin');
    }
    
    // Check if current user is any valid role
    function isValidUser() {
      return hasRole('cashier') || hasRole('staff') || hasRole('admin');
    }
    
    // Check if user is active
    function isActiveUser() {
      return isAuthenticated() && getUserData().isActive == true;
    }
    
    // ==================== USERS COLLECTION ====================
    
    match /users/{userId} {
      // Users can read their own document; admins can read all users.
      // Read is intentionally NOT gated on isActiveUser() so a deactivated
      // user can still discover their isActive=false state on login.
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());

      // Writes require an active session. Without isActiveUser() a
      // deactivated admin could still mint/delete accounts as long as their
      // auth session was valid (regression caught by the rules suite).
      allow create: if isAdmin() && isActiveUser();

      // Users can update their own non-role fields (displayName, password handled by Auth).
      // Admins can update any user.
      allow update: if isAuthenticated() && isActiveUser() && (
        (request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive'])) ||
        isAdmin()
      );

      allow delete: if isAdmin() && isActiveUser();
    }
    
    // ==================== PRODUCTS COLLECTION ====================
    
    match /products/{productId} {
      // All valid users can read products (for POS and inventory view)
      allow read: if isValidUser() && isActiveUser();
      
      // Admin and staff can create products. Staff enter a cost CODE that the
      // app decodes to cost, so there is no field-level cost constraint here.
      // Cashier cannot create. Delete stays admin-only.
      allow create: if (isAdmin() || hasRole('staff')) && isActiveUser();
      allow delete: if isAdmin() && isActiveUser();

      // Admin can update any product field
      allow update: if isAdmin() && isActiveUser();

      // Staff can update product fields EXCEPT sku, price, cost, and costCode
      // (SKU edits are admin-only). Unchanged values never appear in
      // affectedKeys(), so a staff edit that leaves sku alone still passes.
      allow update: if hasRole('staff') && isActiveUser() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sku', 'price', 'cost', 'costCode']);

      // Cashier can update name + imageUrl. Denylist is intentionally
      // limited to **non-nullable** fields (sku, costCode, cost, price,
      // quantity, isActive) so it doesn't trip on the client's
      // toUpdateMap(), which writes every product field — including
      // nullable ones as null. Older docs missing those nullable fields
      // would otherwise count their addition as a "change" and fail the
      // rule even when the cashier didn't touch them. Defense-in-depth
      // for less-critical fields (category, notes, supplier, etc.) is
      // enforced client-side by UpdateProductUseCase.
      allow update: if hasRole('cashier') && isActiveUser() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'sku', 'costCode', 'cost', 'price', 'quantity', 'isActive'
        ]);

      // Any valid user can update stock (quantity) during sale processing.
      // updatedByName is included because ProcessSaleUseCase records the
      // cashier's name on the stock write; without it, cashier sales would
      // complete but silently fail to deduct inventory.
      allow update: if isValidUser() && isActiveUser() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'updatedAt', 'updatedBy', 'updatedByName']);
      
      // Price history subcollection
      match /price_history/{historyId} {
        allow read: if isAdmin() && isActiveUser();
        allow write: if isAdmin() && isActiveUser();
      }
    }

    // The price-change report reads price_history via a collection-group query.
    // The nested products/*/price_history rule above governs writes and
    // per-product reads; this recursive-wildcard rule authorizes the group
    // query. Admin-only, matching the nested rule.
    match /{path=**}/price_history/{historyId} {
      allow read: if isAdmin() && isActiveUser();
    }

    // ==================== SUPPLIERS COLLECTION ====================
    
    match /suppliers/{supplierId} {
      // Only admin can access suppliers
      allow read, write: if isAdmin() && isActiveUser();
    }
    
    // ==================== SALES COLLECTION ====================
    
    match /sales/{saleId} {
      // All valid users can read sales (for reports based on role)
      // App-level logic restricts cashier/staff to today's sales only
      allow read: if isValidUser() && isActiveUser();
      
      // All valid users can create sales (POS)
      allow create: if isValidUser() && isActiveUser();
      
      // Only admin can update sales (for voiding)
      // Staff and cashier CANNOT void sales
      allow update: if isAdmin() && isActiveUser();
      
      // No one can delete sales (audit trail)
      allow delete: if false;
      
      // Sale items subcollection
      match /items/{itemId} {
        allow read: if isValidUser() && isActiveUser();
        allow write: if isValidUser() && isActiveUser();
      }
    }
    
    // ==================== DRAFTS COLLECTION ====================
    
    match /drafts/{draftId} {
      // All valid active users can read drafts
      allow read: if isValidUser() && isActiveUser();

      // Users can create drafts
      allow create: if isValidUser() && isActiveUser() &&
        request.resource.data.createdBy == request.auth.uid;

      // Ticket edits stay creator-or-admin. One narrow exception: whoever
      // rings the ticket up at the register may mark it converted — bill-out
      // writes exactly the conversion fields — regardless of who created it.
      // Two invariants stay pinned server-side:
      // - createdBy is immutable, otherwise the creator-or-admin rules could
      //   be laundered by rewriting createdBy first;
      // - a converted (billed-out) ticket is frozen, so a stale editor can
      //   never flip isConverted back and let the ticket be billed twice.
      allow update: if isValidUser() && isActiveUser() &&
        request.resource.data.createdBy == resource.data.createdBy &&
        resource.data.get('isConverted', false) == false &&
        (
          resource.data.createdBy == request.auth.uid || isAdmin() ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['isConverted', 'convertedToSaleId', 'convertedAt', 'updatedAt']
          ) && request.resource.data.isConverted == true)
        );

      // Deleting a ticket stays creator-or-admin.
      allow delete: if isValidUser() && isActiveUser() &&
        (resource.data.createdBy == request.auth.uid || isAdmin());
    }
    
    // ==================== RECEIVINGS COLLECTION ====================

    match /receivings/{receivingId} {
      // Staff and admin can read receivings
      allow read: if isStaffOrAdmin() && isActiveUser();

      // Staff and admin can create/update receivings
      allow create, update: if isStaffOrAdmin() && isActiveUser();

      // Only admin can delete receivings
      allow delete: if isAdmin() && isActiveUser();
    }

    // ==================== PURCHASE ORDERS COLLECTION ====================

    match /purchase_orders/{purchaseOrderId} {
      // Staff and admin can read purchase orders
      allow read: if isStaffOrAdmin() && isActiveUser();

      // Staff and admin can create/update purchase orders
      allow create, update: if isStaffOrAdmin() && isActiveUser();

      // Only admin can delete purchase orders
      allow delete: if isAdmin() && isActiveUser();
    }

    // ==================== EXPENSES COLLECTION ====================
    
    match /expenses/{expenseId} {
      // All valid users can read expenses
      allow read: if isValidUser() && isActiveUser();
      
      // All valid users can create expenses (cashier/staff can add)
      allow create: if isValidUser() && isActiveUser();
      
      // All valid users can update/delete expenses (shop policy 2026-07-04:
      // cashier/staff fix and remove their own entry mistakes; the activity
      // log keeps the audit trail)
      allow update, delete: if isValidUser() && isActiveUser();
    }
    
    // ==================== DAILY CLOSINGS COLLECTION ====================

    match /daily_closings/{closingId} {
      // Any active valid user (cashier/staff/admin) can read closings.
      allow read: if isValidUser() && isActiveUser();

      // Active valid users can create a closing (cashier closes, admin too).
      allow create: if isValidUser() && isActiveUser();

      // Closings are immutable once saved (audit record).
      allow update, delete: if false;
    }

    // ==================== USER LOGS COLLECTION ====================
    
    match /user_logs/{logId} {
      // Only admin can read logs
      allow read: if isAdmin() && isActiveUser();
      
      // System can create logs (all authenticated users)
      allow create: if isAuthenticated();
      
      // No one can update or delete logs (audit trail)
      allow update, delete: if false;
    }
    
    // ==================== SETTINGS COLLECTION ====================

    match /settings/{settingId} {
      // All valid users can read settings
      allow read: if isValidUser() && isActiveUser();

      // Only admin can modify settings
      allow write: if isAdmin() && isActiveUser();

      // Exception: sale_counters holds the daily sale-number sequence.
      // Generating a sale number at checkout increments it inside the
      // createSale transaction, so cashier/staff must be able to write this
      // one doc — otherwise non-admin checkouts fail with permission-denied.
      allow write: if settingId == 'sale_counters' &&
        isValidUser() && isActiveUser();
    }

    // ==================== PRODUCT CATEGORIES COLLECTION ====================

    match /product_categories/{categoryId} {
      // All valid users can read categories (product form, inventory filter)
      allow read: if isValidUser() && isActiveUser();

      // Only admin can manage the category list
      allow write: if isAdmin() && isActiveUser();
    }

    // ==================== EXPENSE CATEGORIES COLLECTION ====================

    match /expense_categories/{categoryId} {
      // All valid users can read categories (expense form)
      allow read: if isValidUser() && isActiveUser();

      // Only admin can manage the category list
      allow write: if isAdmin() && isActiveUser();
    }

    // ==================== UNITS COLLECTION ====================

    match /units/{unitId} {
      // All valid users can read units (product form, inventory display)
      allow read: if isValidUser() && isActiveUser();

      // Only admin can manage the unit list
      allow write: if isAdmin() && isActiveUser();
    }

    // ==================== VOID REASONS COLLECTION ====================

    match /void_reasons/{reasonId} {
      // All valid users can read void reasons (void-sale dialog dropdown)
      allow read: if isValidUser() && isActiveUser();

      // Only admin can manage the void-reason list
      allow write: if isAdmin() && isActiveUser();
    }

    // ==================== MECHANICS COLLECTION ====================

    match /mechanics/{mechanicId} {
      // All valid users can read mechanics — the cashier-facing mechanic
      // picker on service drafts/sales streams active mechanics, so read is
      // intentionally NOT admin-only (mirrors void_reasons / categories).
      allow read: if isValidUser() && isActiveUser();

      // Only admin can manage the mechanic list (Settings → Mechanics editor,
      // gated by the manageCategories permission at the route layer).
      allow write: if isAdmin() && isActiveUser();
    }

    // ==================== MOTORCYCLE MODELS COLLECTION ====================

    match /motorcycle_models/{modelId} {
      // Cashier-facing Job Order picker streams active models — read is not
      // admin-only (mirrors mechanics).
      allow read: if isValidUser() && isActiveUser();

      // Pick-or-add: any active user may create a model inline (like /drafts).
      allow create: if isValidUser() && isActiveUser() &&
        request.resource.data.createdBy == request.auth.uid;

      // Only admin manages the list (Settings → Motorcycle Models: rename /
      // archive), gated by manageCategories at the route layer.
      allow update, delete: if isAdmin() && isActiveUser();
    }

    // ==================== VOID REQUESTS COLLECTION ====================

    match /void_requests/{requestId} {
      // Any active valid user can read (pending indicator + admin queue).
      allow read: if isValidUser() && isActiveUser();

      // Requester creates their own pending request.
      allow create: if isValidUser() && isActiveUser() &&
        request.resource.data.requestedBy == request.auth.uid &&
        request.resource.data.status == 'pending';

      // Only admin resolves (approve/reject) or marks read.
      allow update: if isAdmin() && isActiveUser();

      // Audit trail — no deletes.
      allow delete: if false;
    }

    // SKU-uniqueness guard: one claim doc per in-use SKU
    // (key = normalizeSku(sku) = sku.trim().toUpperCase()). Reserved atomically in a
    // transaction by the product create / SKU-rename paths (slices B/C). Slice A only
    // declares the rules + backfills claims; no client enforces it yet.
    match /product_skus/{sku} {
      // The claim transaction's tx.get must succeed for any creator; no secrets here.
      allow read:   if isValidUser() && isActiveUser();
      // MIRROR the products create rule (admin OR staff) — admin-only here would
      // half-commit every staff product create (product written, claim denied).
      allow create: if (isAdmin() || hasRole('staff')) && isActiveUser();
      // Only an admin rename (frees old) or a hard delete frees a claim.
      allow delete: if isAdmin() && isActiveUser();
      // Claims are create/delete only — block update so a claim can't be repointed.
      allow update: if false;
    }

    // Barcode uniqueness claim (Slice A). One product_barcodes/{normalizeBarcode(code)}
    // doc per in-use barcode; enforced in transactions by the product create / barcode
    // edit paths (slices B/C). Slice A only declares the rules + backfills; no client
    // enforces it yet. Policy MIRRORS product_skus.
    match /product_barcodes/{barcode} {
      allow read:   if isValidUser() && isActiveUser();
      // Mirror the products create rule (admin OR staff) so a staff product create
      // doesn't half-commit (product written, claim denied).
      allow create: if (isAdmin() || hasRole('staff')) && isActiveUser();
      // Only an admin rename (frees old) or a hard delete frees a claim.
      allow delete: if isAdmin() && isActiveUser();
      // Claims are create/delete only — block update so a claim can't be repointed.
      allow update: if false;
    }
  }
}
