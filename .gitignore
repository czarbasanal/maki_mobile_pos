# Firebase config (client keys — keep out of version control)
lib/firebase_options.dart
android/app/google-services.json

# Dropped platforms (commit 11a7338 — target Android + web only). Ignored so a
# stray `flutter create .` can't re-add them or clutter `git status`.
/ios/
/macos/
/linux/
/windows/

# operational scripts deps
scripts/node_modules/

# stray node_modules at repo root (root is Flutter-only; npm lives in web_admin/)
/node_modules/
