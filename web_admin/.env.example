# Firebase web config — copy to .env.local and fill in real values.
# These mirror lib/firebase_options.dart `web` block.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=maki-mobile-pos.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=maki-mobile-pos
VITE_FIREBASE_STORAGE_BUCKET=maki-mobile-pos.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1075663897179
VITE_FIREBASE_APP_ID=

# Set to "true" to point at the local Firebase emulator suite.
VITE_USE_FIREBASE_EMULATOR=false
VITE_FIREBASE_EMULATOR_HOST=localhost
